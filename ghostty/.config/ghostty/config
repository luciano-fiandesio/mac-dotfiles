# use: https://ghostty.zerebos.com

# Window settings
window-decoration = false
window-inherit-working-directory = true
window-theme = dark
window-save-state = always
window-width = 1920
window-height = 1080

# Mouse settings
mouse-hide-while-typing = true
copy-on-select = true

# Clipboard settings
clipboard-read = allow
clipboard-write = allow
copy-on-select = true

# Background and transparency settings
background = #282a36
background-opacity = 0.8
background-blur = 4

# Fonts
# use `ghostty +list-fonts`
font-family = "MonoLisa"
font-family-bold = "MonoLisa Bold"
font-family-italic = "MonoLisa Bold Italic"
font-family-bold-italic = "MonoLisa Bold Italic"
font-size = 13
adjust-underline-position = 4
cursor-style = block

# Theme
#theme = GitHub Dark
# background-opacity = 0.95
# Color scheme (Dracula-inspired dark theme)
foreground = #f8f8f2
selection-foreground = #ffffff
selection-background = #44475a
cursor-color = #f8f8f2

# ANSI Colors (Dracula)
palette = 0=#21222c
palette = 1=#ff5555
palette = 2=#50fa7b
palette = 3=#f1fa8c
palette = 4=#bd93f9
palette = 5=#ff79c6
palette = 6=#8be9fd
palette = 7=#f8f8f2
palette = 8=#6272a4
palette = 9=#ff6e6e
palette = 10=#69ff94
palette = 11=#ffffa5
palette = 12=#d6acff
palette = 13=#ff92df
palette = 14=#a4ffff
palette = 15=#ffffff
